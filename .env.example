# Mattermost
MATTERMOST_URL=https://mm.example.com
MATTERMOST_TOKEN=
MATTERMOST_BOT_USER_ID=
MATTERMOST_BOT_USERNAME=seed
# MATTERMOST_TEAM=
# MATTERMOST_CHANNEL=
# MATTERMOST_CHANNEL_ID=
# false — если сервер с самоподписанным/корпоративным сертификатом (например mm.sberdevices.ru)
MATTERMOST_VERIFY_TLS=false
REPLY_ALL=false
MENTION_REQUIRED=true

# GigaChat (OAuth или ключ)
GIGACHAT_CLIENT_ID=
GIGACHAT_CLIENT_SECRET=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=GigaChat
GIGACHAT_EMBEDDINGS_MODEL=Embeddings
# false — если OAuth/API за корпоративным сертификатом (например ngw.devices.sberbank.ru)
GIGACHAT_VERIFY_TLS=false
# Или один ключ вместо client_id/secret:
# GIGACHAT_AUTH_KEY=

# MongoDB (docs + cases)
MONGO_URI=mongodb://localhost:27017
MONGO_DB=seed_bot

# Эмбеддинги: true = локально (sentence-transformers), false = GigaChat API
USE_LOCAL_EMBEDDINGS=true
# Многоязычная модель (русский + английский). Варианты: paraphrase-multilingual-MiniLM-L12-v2 (384), paraphrase-multilingual-mpnet-base-v2 (768)
LOCAL_EMBEDDINGS_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Qdrant (облако/сервер с авторизацией — укажи API ключ)
# HTTP API. Порт берётся из qdrant: service.http_port (в твоём конфиге — 8033, по умолчанию 6333)
QDRANT_URL=http://HOST:8033
QDRANT_API_KEY=
QDRANT_COLLECTION=knowledge
QDRANT_LIMIT=5
