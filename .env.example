### ══════════════════════════════════════
### Mattermost
### ══════════════════════════════════════
MATTERMOST_URL=https://mm.example.com
MATTERMOST_TOKEN=put-token-here
MATTERMOST_BOT_USER_ID=put-bot-user-id-here
MATTERMOST_BOT_USERNAME=seed

# Опционально: ограничить один каналом
# MATTERMOST_TEAM=myteam
# MATTERMOST_CHANNEL=town-square
# MATTERMOST_CHANNEL_ID=

# Режим ответов
REPLY_ALL=false
MENTION_REQUIRED=true

# TLS
MATTERMOST_WS_VERIFY_TLS=true

### ══════════════════════════════════════
### GigaChat
### ══════════════════════════════════════
GIGACHAT_CLIENT_ID=put-client-id-here
GIGACHAT_CLIENT_SECRET=put-client-secret-here
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=GigaChat-2
GIGACHAT_VERIFY_TLS=false

# Ограничение запросов в минуту (token bucket)
GIGACHAT_RATE_LIMIT=20

# Streaming: бот начинает печатать сразу, не ждёт полного ответа
GIGACHAT_STREAMING=true

### ══════════════════════════════════════
### MongoDB (опционально)
### ══════════════════════════════════════
# MONGO_URI=mongodb://localhost:27017
# MONGO_DB=seed_bot

### ══════════════════════════════════════
### Webhook сервер (опционально)
### Принимает алерты от Grafana / Alertmanager / Zabbix
### ══════════════════════════════════════
# WEBHOOK_PORT=8080
# WEBHOOK_SECRET=mysecret

### ══════════════════════════════════════
### Daily digest (опционально)
### Требует MONGO_URI + DIGEST_CHANNEL_ID
### ══════════════════════════════════════
# DIGEST_CHANNEL_ID=channel-id-here
# DIGEST_TIME=09:00
