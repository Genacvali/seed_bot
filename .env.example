# Mattermost
MATTERMOST_URL=https://mm.example.com
MATTERMOST_TOKEN=
MATTERMOST_BOT_USER_ID=
MATTERMOST_BOT_USERNAME=seed

# GigaChat
GIGACHAT_CLIENT_ID=
GIGACHAT_CLIENT_SECRET=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=GigaChat-2
GIGACHAT_VERIFY_TLS=false
GIGACHAT_RATE_LIMIT=20

# MongoDB — история диалогов и контекст
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=seed_bot
MONGODB_HISTORY_TTL_DAYS=30
HISTORY_LIMIT=50

MENTION_REQUIRED=true
